{
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{node_modules,dist,frontend,data/processed,data/raw,.vercel/python/.venv/lib/python*/site-packages/nvidia*}/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
