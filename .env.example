# =========================================================================
# API KEYS CONFIGURATION (Copy this file to .env and insert your keys)
# =========================================================================

# Google Gemini API Key (Get it from: https://aistudio.google.com/ - Free Tier)
GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face API Token (Get it from: https://huggingface.co/settings/tokens - Free)
# Required for calling FinBERT sentiment analysis serverless API
HF_API_KEY=your_hugging_face_api_key_here

# NewsAPI Key (Get it from: https://newsapi.org/ - Free Developer Tier)
NEWS_API_KEY=your_news_api_key_here
